{
  "name": "mcp-onedrive-sharepoint",
  "version": "1.0.0",
  "description": "MCP server for OneDrive/SharePoint integration",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc --pretty false",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "start": "node build/index.js",
    "stdio": "./scripts/run-stdio.sh",
    "spcall": "./scripts/spcall.sh",
    "setup-auth": "tsx src/auth/setup-auth.ts",
    "test": "npm run build && node --test build/tests/*.test.js",
    "lint": "eslint . --ext .ts --max-warnings 393",
    "ci": "npm run build && npm run lint && npm test",
    "format": "prettier --write \"src/**/*.ts\" README.md docs/**/*.md scripts/*.mjs"
  },
  "keywords": [
    "mcp",
    "onedrive",
    "sharepoint",
    "microsoft-graph"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@azure/msal-node": "^2.6.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.7",
    "dotenv": "^16.4.1",
    "form-data": "^4.0.0",
    "keytar": "^7.9.0",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.16",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "bin": {
    "mcp-onedrive-sharepoint": "./build/index.js",
    "ods": "./build/cli.js",
    "sharepoint-mcp-stdio": "./scripts/run-stdio.sh",
    "spcall": "./scripts/spcall.sh"
  }
}
